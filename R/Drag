#KWICS x temporada
season_kwic <- split(toks_kwic, f=docvars(toks_kwic, "season"))

kwic_eltern_season <- lapply(names(season_kwic), function(s) {
  res <- kwic(season_kwic [[s]], pattern = c("mother*", "mom", "father*", "dad",
                                     "moms", "dads", "MILF", "DILF"), window = 5)
  res$Season <- s
  return(res)
})

kwic_royal_season <- lapply(names(season_kwic), function(s) {
  res <- kwic(season_kwic [[s]], pattern = c("queen*", "king*", "princess*", "prince",
                                     "princes"), window = 5)
  res$Season <- s
  return(res)
})

kwic_pronoun_season <- lapply(names(season_kwic), function(s) {
  res <- kwic(season_kwic [[s]], pattern = c("she", "her", "he", "him"), window = 5)
  res$Season <- s
  return(res)
})

kwic_performance_season <- lapply(names(season_kwic), function(s) {
  res <- kwic(season_kwic [[s]], pattern = c("work", "werk", "runway", "yass*",
                                             "tear the house down", "slay"), window = 5)
  res$Season <- s
  return(res)
})

kwic_person_season <- lapply(names(season_kwic), function(s) {
  res <- kwic(season_kwic [[s]], pattern = c("girl*", "boy*", "woman", "women",
                                             "man", "men"), window = 5)
  res$Season <- s
