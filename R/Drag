#colocaciones de kwics

mom <- c("mother", "mothers", "mom", "moms")
dad <- c("dad", "dads", "father", "fathers")
king <- c("king", "kings")
queen <- c("queen", "queens")
queendom <- "queendom"
kingdom <- "kingdom"
runway <- "runway"
yass <- "yass"
slay <- "slay"
work <- c("work", "werk")
gf <- "girlfriend"
bf <- "boyfriend"


kwic_mom <- kwic(toks_clean, pattern = c("mother", "mothers", "mom", "moms"),
                  window = 1)
kwic_dad <- kwic(toks_clean, pattern = c("dad", "dads", "father", "fathers"),
                 window = 1)
kwic_king <- kwic(toks_clean, pattern = c("king", "kings"), window = 1)
kwic_queen <- kwic(toks_clean, pattern = c("queen", "queens"), window = 1)
kwic_queendom <- kwic(toks_clean, pattern = "queendom", window = 1)
kwic_kingdom <- kwic(toks_clean, pattern = "kingdom", window = 1)
kwic_runway <- kwic(toks_clean, pattern = "runway", window = 1)
kwic_yass <- kwic(toks_clean, pattern = "yass", window = 1)
kwic_slay <- kwic(toks_clean, pattern = "slay", window = 1)
kwic_work <- kwic(toks_clean, pattern = c("work", "werk"), window = 1)
kwic_gf <- kwic(toks_clean, pattern = "girlfriend", window = 1)
kwic_bf <- kwic(toks_clean, pattern = "boyfriend", window = 1)

colloqs <-  list(mom = kwic_mom,
                 dad = kwic_dad,
                 king = kwic_king,
                 queen = kwic_queen,
                 queendom = kwic_queendom,
                 kingdom = kwic_kingdom,
                 runway = kwic_runway,
                 yass = kwic_yass,
                 slay = kwic_slay,
                 work = kwic_work,
                 gf = kwic_gf,
                 bf = kwic_bf)


colloqs_pre <- lapply(colloqs, function(f){
  f %>% 
    as.data.frame() %>% 
    mutate (Key = case_when(
      pattern %in% mom ~ "Mother",
      pattern %in% dad ~ "Father",
      pattern %in% king ~ "King",
      pattern %in% queen ~ "Queen",
      pattern %in% queendom ~ "Queendom",
      pattern %in% kingdom ~ "Kingdom",
      pattern %in% runway ~ "Runway",
      pattern %in% yass ~ "Yass",
      pattern %in% slay ~ "Slay",
      pattern %in% work ~ "Werk",
      pattern %in% gf ~ "Girlfriend",
      pattern %in% bf ~ "Boyfriend"
    )) %>% 
    count(pre = tolower(pre), Key) %>% 
    arrange(desc(n)) %>% 
    slice(1:5)
})

colloqs_post <- lapply(colloqs, function(f){
  f %>% 
    as.data.frame() %>% 
    mutate (Key = case_when(
      pattern %in% mom ~ "Mother",
      pattern %in% dad ~ "Father",
      pattern %in% king ~ "King",
      pattern %in% queen ~ "Queen",
      pattern %in% queendom ~ "Queendom",
      pattern %in% kingdom ~ "Kingdom",
      pattern %in% runway ~ "Runway",
      pattern %in% yass ~ "Yass",
      pattern %in% slay ~ "Slay",
      pattern %in% work ~ "Werk",
      pattern %in% gf ~ "Girlfriend",
      pattern %in% bf ~ "Boyfriend"
    )) %>% 
    count(post = tolower(post), Key) %>% 
    arrange(desc(n)) %>% 
    slice(1:5)
})



