#Path to data
setwd("[...]")
options(max.print = 900000)

raw_data <- readtext("S*/*.txt", 
                     docvarsfrom = "filepath", 
                     dvsep = "/", 
                     docvarnames = c("season", "episode"))

raw_data$episode <- gsub(".txt", "", raw_data$episode)

subs <- raw_data[, c("season", "episode", "text")]

Corpus <- corpus(subs, text_field = "text")

toks_clean <- tokens(Corpus, remove_punct = T, remove_symbols = F, 
                     remove_numbers = T, remove_url = T, include_docvars = T, padding = F)%>%
  tokens_remove(pattern = stopwords("en", source = "stopwords-iso"), padding = T)%>%
  tokens_remove (pattern = c("Previously on RuPaul's Drag Race", "phi", "chi")) %>% 
  tokens_remove (pattern = "\\[.*?\\]", valuetype = "regex") %>% 
  tokens_keep(pattern = "^[\\p{script=Latn}]+$", valuetype = "regex")

toks_kwic <- tokens(Corpus)

dfmat_kwic <- dfm(toks_kwic)
dfmat_clean <- dfm(toks_clean)

seasons <- sprintf("S%02d", 1:16)

#Topfeatures
tstat_freq_all <- textstat_frequency(dfmat_clean, n = 30)

Topfeat_all_plot <- ggplot(tstat_freq_all, aes(x=reorder(feature, frequency),
                                            y=frequency)) +
  geom_col(fill = "violetred") +
  scale_y_continuous(labels = comma_format(big.mark = ".",
                                           decimal.mark = ","),
                     expand = c(0,0)) + 
  theme(axis.text.x = element_text(angle = 45, hjust = 1)) +
  coord_flip() +
  labs (y = "Frecuencia", x=NULL) +
  ggtitle("30 Palabras más frecuentes")


#KWICs

kwic_eltern <- kwic(toks_kwic, pattern = c("mother*", "mom", "father*", "dad",
                    "moms", "dads", "MILF", "DILF"), window = 5)
kwic_royal <- kwic(toks_kwic, pattern = c("queen*", "king*", "princess*", "prince",
                                          "princes"), window = 5)
kwic_pronoun <- kwic(toks_kwic, pattern = c("she", "her", "he", "him"), window = 5)
kwic_perform <- kwic(toks_kwic, pattern = c("work", "werk", "runway", "yass*",
                                            "tear the house down", "slay"), window = 5)
kwic_person <- kwic(toks_kwic, pattern = c("girl*", "boy*", "woman", "women",
                                           "man", "men"), window = 5)


Fem <- c("mother*", "mom", "moms", "queen*", "princess*", "she", "her", "MILF",
         "girl*", "woman", "women")
Masc <- c ("father*", "dad", "dads", "king*", "prince", "princes", "he", "him",
           "DILF", "boy*", "man", "men")


kwic_list <- list(pronouns = kwic_pronoun,
                  Eltern = kwic_eltern,
                  royal = kwic_royal,
                  performance = kwic_perform,
                  person = kwic_person)

kwics_counts <- lapply(kwic_list, function(cw){
  cw %>% 
    as.data.frame() %>% 
    mutate(gender = case_when(
      pattern %in% Fem ~ "Femenine",
      pattern %in% Masc ~ "Masculine",
      TRUE ~ "Otro"
    )) %>% 
    count(keyword = tolower(keyword), gender) %>% 
    arrange(desc(n))
})


Graphs_kwic <- lapply(kwics_counts, function(gr) {
  gr %>% 
    ggplot(mapping = aes(x=reorder(keyword, -n), y =n, fill=gender)) +
    geom_col() +
    scale_y_log10() +
    scale_fill_manual("Género", values = c("Femenine" = "#D60270",
                                           "Masculine" = "#0038A8",
                                           "Otro" = "#9B4F96")) +
    theme(panel.background = element_rect(fill = "white")) +
    coord_flip() +
    labs (x="Keywords", y = "Frecuencia: Escala Logarítmica")
})

Graphs_kwic_pronouns <- ggplot(kwics_counts$pronouns,
